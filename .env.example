# Do not commit .env — copy to .env.local for local yoco-backend only.
# On Vercel, set these in Project → Settings → Environment Variables.

# Secret key only (sk_live_... or sk_test_...), NOT pk_...
YOCO_SECRET_KEY=sk_test_replace_me

SITE_URL=https://www.llandudnoshack.co.za

# Full service account JSON as ONE line, from:
# node yoco-backend/scripts/minify-firebase-key.js ~/Downloads/shack-30405-xxxxx.json
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"shack-30405"}
